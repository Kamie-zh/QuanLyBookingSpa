@startuml
left to right direction
skinparam packageStyle rectangle

actor "Guest" as Guest
actor "User (Khách Hàng)" as User
actor "Admin (Quản Trị Viên)" as Admin
actor "System (Hệ Thống)" as System

rectangle "Beauty Spa Booking System" {
  Guest -- (Xem Trang Chủ & Dịch Vụ)
  Guest -- (Đăng Ký & Đăng Nhập)
  Guest -- (Quên Mật Khẩu / Reset)

  User -- (Tra Cứu Lịch Trống)
  User -- (Đặt Lịch Dịch Vụ)
  User -- (Xem Lịch Hẹn & Hóa Đơn)
  User -- (Hủy Lịch)
  User -- (Áp Dụng Voucher VIP)

  (Xác Nhận / Hủy Lịch Hẹn) -- Admin
  (Quản Lý Dịch Vụ & Banner) -- Admin
  (Quản Lý Khách Hàng) -- Admin
  (Thêm Dịch Vụ Vào Hóa Đơn) -- Admin
  (Quản Lý Khuyến Mãi) -- Admin
  (Thống Kê Báo Cáo) -- Admin

  (Tự Động Nâng Cấp VIP) -- System
  (Auto-Confirm Lịch Hẹn) -- System
  (Gửi Email Thông Báo) -- System
}

User -|> Guest
@enduml
